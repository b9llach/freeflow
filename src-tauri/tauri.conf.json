{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freeflow",
  "version": "0.1.0",
  "identifier": "com.freeflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Freeflow",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "indicator",
        "url": "indicator.html",
        "title": "Freeflow Indicator",
        "width": 160,
        "height": 56,
        "x": 20,
        "y": 20,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
